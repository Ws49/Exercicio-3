<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/assets/style.css"/>
    <link rel="shortcut icon" href="/assets/icon.png" type="image/x-icon" />
    <title>Car {{id}}</title>
</head>
<body>
     <main class="container">
        <div class="content-car">
            <form method="POST">
                <input type="text" name="name" id="name" value="{{name}}" readonly>
                <input type="text" name="placa" id="placa" value="{{placa}}">
                <input type="text" name="type" id="type" value="{{type}}">
                <input type="number" name="power" id="power" value="{{power}}">
                <input type="file" name="photo" class="input-photo-car" accept="image/png, image/jpeg ">
                <button type="submit" formaction="/car/update/{{id}}" class="updateCar">Salvar</button>
                <button type="submit" formaction="/car/delete/{{id}}" class="delCar">Deletar</button>
            </form>
            <img src="/assets/icon.png">
        </div>
    </main>
</body>
</html>