<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Car {{id}}</title>
</head>
<body>
    <form action="http://0.0.0.0:4444/cars" method="POST">
        <input type="text" name="name" id="name" value="{{name}}" readonly>
        <input type="text" name="placa" id="placa" value="{{placa}}" readonly>
        <input type="text" name="type" id="type" value="{{type}}" readonly>
        <input type="number" name="power" id="power" value="{{power}}" readonly>
        <button type="submit">enviar</button>
    </form>
</body>
</html>